# Repository-local generated output and editor noise. This file is not a shared
# standards payload; each consumer owns the ignore list for its own toolchain.

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vs/
.vscode/*
!.vscode/extensions.json

# Claude Code worktrees (per-checkout; PR worktree workflow)
.claude/worktrees/

# Node
node_modules/

# Python tooling
.ruff_cache/

# Lefthook — per-developer override config and local-only scripts dir
lefthook-local.yml
.lefthook-local/

# .NET — build output from the dotnet fixtures
bin/
obj/

# Local npm pack output (CI writes packages to a temporary directory).
components/*/*.tgz
