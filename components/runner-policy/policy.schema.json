{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://standards.melodic.software/runner-policy/policy.schema.json",
  "title": "Runner policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "selectorWorkflowPaths",
    "approvedSelectorReferences",
    "approvedSelectorReferencesByRepositoryOwner",
    "approvedReusableWorkflowContracts",
    "canonicalSelectorInputs",
    "optionalCanonicalSelectorInputs",
    "canonicalSelectorSecrets",
    "approvedHostedRunnerLabels",
    "hostedMatrixExpressions",
    "governedReusableRunnerInput",
    "forbiddenHostedRunnerLabels",
    "managedLabelPatterns",
    "hostedExceptionReasons",
    "localCredentialActions"
  ],
  "properties": {
    "schemaVersion": { "const": 3 },
    "selectorWorkflowPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/reusableWorkflowPath" }
    },
    "approvedSelectorReferences": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/reusableWorkflowReference" }
    },
    "approvedSelectorReferencesByRepositoryOwner": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/repositoryOwner" },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "$ref": "#/$defs/reusableWorkflowReference" }
      }
    },
    "approvedReusableWorkflowContracts": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/reusableWorkflowReference" },
      "additionalProperties": { "$ref": "#/$defs/reusableWorkflowContract" }
    },
    "canonicalSelectorInputs": { "$ref": "#/$defs/nonEmptyStringMap" },
    "optionalCanonicalSelectorInputs": { "$ref": "#/$defs/stringMap" },
    "canonicalSelectorSecrets": { "$ref": "#/$defs/nonEmptyStringMap" },
    "approvedHostedRunnerLabels": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
    "hostedMatrixExpressions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^\\$\\{\\{ matrix\\.[A-Za-z0-9_-]+ \\}\\}$"
      }
    },
    "governedReusableRunnerInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "expression", "default", "failureSentinel"],
      "properties": {
        "name": { "$ref": "#/$defs/nonWhitespaceString" },
        "expression": { "$ref": "#/$defs/nonWhitespaceString" },
        "default": { "$ref": "#/$defs/nonWhitespaceString" },
        "failureSentinel": { "const": "ci-runner-selection-failed" }
      }
    },
    "forbiddenHostedRunnerLabels": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
    "managedLabelPatterns": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
    "hostedExceptionReasons": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
    "localCredentialActions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_.-]+/[a-z0-9_.-]+$"
      }
    }
  },
  "$defs": {
    "nonWhitespaceString": {
      "type": "string",
      "pattern": "\\S"
    },
    "repositoryOwner": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9]|-(?=[a-z0-9])){0,38}$"
    },
    "reusableWorkflowPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/\\.github/workflows/[A-Za-z0-9_.-]+\\.ya?ml$"
    },
    "reusableWorkflowReference": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/\\.github/workflows/[A-Za-z0-9_.-]+\\.ya?ml@[0-9a-fA-F]{40}$"
    },
    "inputName": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "stringMap": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/nonWhitespaceString" },
      "additionalProperties": { "$ref": "#/$defs/nonWhitespaceString" }
    },
    "nonEmptyStringMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/nonWhitespaceString" },
      "additionalProperties": { "$ref": "#/$defs/nonWhitespaceString" }
    },
    "uniqueStringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonWhitespaceString" }
    },
    "nonEmptyUniqueStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonWhitespaceString" }
    },
    "readWritePermissionAccess": { "enum": ["read", "write", "none"] },
    "readPermissionAccess": { "enum": ["read", "none"] },
    "writePermissionAccess": { "enum": ["write", "none"] },
    "githubPermissionMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "actions": { "$ref": "#/$defs/readWritePermissionAccess" },
        "artifact-metadata": { "$ref": "#/$defs/readWritePermissionAccess" },
        "attestations": { "$ref": "#/$defs/readWritePermissionAccess" },
        "checks": { "$ref": "#/$defs/readWritePermissionAccess" },
        "code-quality": { "$ref": "#/$defs/readWritePermissionAccess" },
        "contents": { "$ref": "#/$defs/readWritePermissionAccess" },
        "deployments": { "$ref": "#/$defs/readWritePermissionAccess" },
        "discussions": { "$ref": "#/$defs/readWritePermissionAccess" },
        "id-token": { "$ref": "#/$defs/writePermissionAccess" },
        "issues": { "$ref": "#/$defs/readWritePermissionAccess" },
        "models": { "$ref": "#/$defs/readPermissionAccess" },
        "packages": { "$ref": "#/$defs/readWritePermissionAccess" },
        "pages": { "$ref": "#/$defs/readWritePermissionAccess" },
        "pull-requests": { "$ref": "#/$defs/readWritePermissionAccess" },
        "security-events": { "$ref": "#/$defs/readWritePermissionAccess" },
        "statuses": { "$ref": "#/$defs/readWritePermissionAccess" },
        "vulnerability-alerts": { "$ref": "#/$defs/readPermissionAccess" }
      }
    },
    "reusableWorkflowContract": {
      "oneOf": [{ "$ref": "#/$defs/runnerInputContract" }, { "$ref": "#/$defs/hostedOnlyContract" }]
    },
    "runnerInputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routing", "runnerInput", "allowedInputs", "allowedSecrets"],
      "properties": {
        "routing": { "const": "runner-input" },
        "runnerInput": { "$ref": "#/$defs/inputName" },
        "selectorResultInput": { "$ref": "#/$defs/inputName" },
        "allowedInputs": { "$ref": "#/$defs/uniqueStringArray" },
        "allowedSecrets": { "$ref": "#/$defs/stringMap" },
        "allowedCallerPermissions": { "$ref": "#/$defs/githubPermissionMap" }
      }
    },
    "hostedOnlyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routing", "allowedInputs", "allowedSecrets", "fixedRunsOn"],
      "properties": {
        "routing": { "const": "hosted-only" },
        "allowedInputs": { "$ref": "#/$defs/uniqueStringArray" },
        "allowedSecrets": { "$ref": "#/$defs/stringMap" },
        "fixedRunsOn": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
      }
    }
  }
}
