{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://standards.melodic.software/runner-policy/repository-policy.schema.json",
  "title": "Repository runner policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "visibility", "selfHostedCi", "exceptions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "repositoryOwner": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9]|-(?=[a-z0-9])){0,38}$"
    },
    "visibility": { "enum": ["public", "private"] },
    "selfHostedCi": { "type": "boolean" },
    "exceptions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^\\.github/workflows/[^/#]+\\.ya?ml#[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason", "justification"],
        "properties": {
          "reason": { "type": "string", "pattern": "\\S" },
          "justification": { "type": "string", "pattern": "\\S" }
        }
      }
    },
    "localRoutingGrants": {
      "type": "object",
      "propertyNames": {
        "pattern": "^\\.github/workflows/[^/#]+\\.ya?ml#[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["permissions", "justification"],
        "properties": {
          "permissions": { "$ref": "#/$defs/githubPermissionMap" },
          "environment": { "type": "string", "pattern": "\\S" },
          "secrets": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            }
          },
          "credentialActions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9_.-]+/[a-z0-9_.-]+$"
            }
          },
          "justification": { "type": "string", "pattern": "\\S" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "visibility": { "const": "public" } },
        "required": ["visibility"]
      },
      "then": {
        "properties": { "selfHostedCi": { "const": false } }
      }
    }
  ],
  "$defs": {
    "readWritePermissionAccess": { "enum": ["read", "write", "none"] },
    "readPermissionAccess": { "enum": ["read", "none"] },
    "writePermissionAccess": { "enum": ["write", "none"] },
    "githubPermissionMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actions": { "$ref": "#/$defs/readWritePermissionAccess" },
        "artifact-metadata": { "$ref": "#/$defs/readWritePermissionAccess" },
        "attestations": { "$ref": "#/$defs/readWritePermissionAccess" },
        "checks": { "$ref": "#/$defs/readWritePermissionAccess" },
        "code-quality": { "$ref": "#/$defs/readWritePermissionAccess" },
        "contents": { "$ref": "#/$defs/readWritePermissionAccess" },
        "deployments": { "$ref": "#/$defs/readWritePermissionAccess" },
        "discussions": { "$ref": "#/$defs/readWritePermissionAccess" },
        "id-token": { "$ref": "#/$defs/writePermissionAccess" },
        "issues": { "$ref": "#/$defs/readWritePermissionAccess" },
        "models": { "$ref": "#/$defs/readPermissionAccess" },
        "packages": { "$ref": "#/$defs/readWritePermissionAccess" },
        "pages": { "$ref": "#/$defs/readWritePermissionAccess" },
        "pull-requests": { "$ref": "#/$defs/readWritePermissionAccess" },
        "security-events": { "$ref": "#/$defs/readWritePermissionAccess" },
        "statuses": { "$ref": "#/$defs/readWritePermissionAccess" },
        "vulnerability-alerts": { "$ref": "#/$defs/readPermissionAccess" }
      }
    }
  }
}
