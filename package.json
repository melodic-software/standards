{
  "name": "standards",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Normative, tested repository-quality components and conventions.",
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "lefthook": "2.1.10",
    "markdownlint-cli2": "0.23.0",
    "semver": "7.8.5",
    "yaml": "2.9.0"
  },
  "scripts": {
    "lint:md": "markdownlint-cli2 --config .markdownlint-cli2.jsonc \"**/*.md\" \"!components/**/fixtures/bad/**\"",
    "lint:hooks": "lefthook validate",
    "lint:concurrency-policy": "node components/concurrency-policy/concurrency-policy.mjs --root .",
    "lint:dependabot-policy": "node components/dependabot-policy/dependabot-policy.mjs --root .",
    "lint:runner-policy": "node components/runner-policy/runner-policy.mjs --root .",
    "test:concurrency-policy": "node --test components/concurrency-policy/concurrency-policy.test.mjs",
    "test:dependabot-policy": "node --test components/dependabot-policy/dependabot-policy.test.mjs",
    "test:lefthook-dotnet": "node --test components/lefthook-dotnet/dotnet-format-staged.test.mjs",
    "test:packages": "node --test harness/packages/package-lifecycle.test.mjs",
    "test:runner-policy": "node --test components/runner-policy/runner-policy.test.mjs"
  }
}
